package com.kh.variable;

public class Variable {
	// 변수: Memory(RAM)에 값을 저장하기 위한 *공간
	public void 바지를저장하는기능() {
		String 옷장 = "긴바지";
		String 행거 = "반바지";
		System.out.println(행거);
	}
	
	// 변수를 사용했을 때 장점
	
	// 점심메뉴 출력 프로그램(키오스크)
	public void findLunchMenu() {
		// 1. 메뉴들을 출력(메뉴명, 가격)
		// 2. 메뉴판을 보고 주문을 했다고 가정
		// 3. 내야할 금액 출력
		System.out.println("--- 변수를 사용하기 전 ---");
		System.out.println("메뉴판 > ");
		System.out.println("1. 트리플 치즈버거 세트(15000)");
		System.out.println("2. 빅맥 세트(8397)");
		System.out.println("3. 슈슈버거 세트(9210)");
		
		// 트리플 치즈버거	4명
		// 빅맥 		    9명
		// 1955         4명
		
		System.out.println("======================");
		System.out.println("트리플 치즈버거 4개 주문");
		System.out.println((15000 * 4) + "원 입니다");
		System.out.println("빅맥 9개 주문");
		System.out.println((8397 * 9) + "원 입니다");
		System.out.println("슈슈버거 4개 주문");
		System.out.println((9210 * 4) + "원 입니다");
		System.out.println("======================");
		
		System.out.println("--- 변수를 사용하기 ---");
		// 메뉴명과 가격이라는 값을 담을 공간
		// 변수를 선언하고 변수공간에 값을 대입해서 사용
		String setOne = "슈슈버거 세트";
		int setOnePrice = 9800;
		String setTwo = "빅맥 세트";
		int setTwoPrice = 8800;
		
		System.out.println("메뉴판 > ");
		System.out.println(setOne + " | 가격: " + setOnePrice + "원");
		System.out.println(setTwo + " | 가격: " + setTwoPrice + "원");
		
		System.out.println("======================");
		System.out.println(setOne + "을 10개 시켰습니다.");
		System.out.println(setOnePrice * 10 + "원 입니다.");
		System.out.println(setTwo + "을 5개 시켰습니다.");
		System.out.println(setTwoPrice * 5 + "원 입니다.");
		System.out.println("======================");
		
		/*
		 * 변수를 사용했을 때
		 * 
		 * 1. 딱 한 번 값을 대입해서 필요한 순간마다 다시 사용할 수 있음
		 * => 재사용성이 높아짐
		 * 2. 동일한 값을 수정해야 할 때 한 번만 수정하면됨
		 * => 실수의 확률이 줄어든다
		 * 3. 값에 의미를 부여할 수 있음
		 * => 가독성이 높아짐
		 */
		
	}
	
	// 변수를 사용하는 방법 연습
	public void declareVariable() {
		/*
		 * 변수 선언 방법
		 * 
		 * int price; 변수 선언
		 * 
		 * 자료형(DataType) 변수식별자;
		 * 
		 * 권장하는 방법은 아니지만 동일한 타입의 변수를 선언할 때는 한 번에 선언할 수 있음
		 * int a, b, c;
		 * 
		 * = : 대입 연산자 | 왼쪽의 공간(변수)에 오른쪽 값을 대입한다.
		 * *공간 = 값*
		 * 
		 * 변수를 선언한 다음 처음 값을 대입하는 과정을 초기화(Initialzating) 라고 한다.
		 * 초기화를 통해 대입한 값을 초기값이라고 한다.
		 * 
		 * 변수는 자신이 선언된 {Scope} 에서만 사용할 수 있음
		 * System.out.println(setOne); 안됨
		 * local variable(지역변수)
		 * 
		 * 식별자(Identifier)
		 * 
		 * 클래스명, 메소드명, 변수명 등 개발자가 만들어서 이용하는 고유의 이름
		 * 
		 * 1. 예약어는 식별자로 사용 할 수 없음(public, void, static 등)
		 * 2. 공백은 포함할 수 없음(int ab c;)
		 * 3. 대, 소문자로 구분하고 길이제한은 없음(abc, Abc, aBc)
		 * 4. 문자, 숫자, _, $를 포함 할 수 있음
		 * 5. 문자, _, $로만 시작할 수 있음
		 *  
		 *  
		 */
		
		
	}
	
	
}


















