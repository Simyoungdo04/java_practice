package com.kh.firtst; // 패키지 선언부: 현재 클래스의 위치

	/* 
	 * 주석(Comments)
	 * 
	 * 주석은 프로그램 실행에 영향 X
	 * 작성된 코드를 쉽게 하기 위해 사용
	 * 주석을 달아 놓으면 유지보수 시간 감소
	 * 
	 * 주석의 종류
	 * 
	 * 1. 한 줄 주석(//): 작성할 내용이 한 줄 일때 사용
	 * 	  // 이후 부터 행의 모든 내용을 주석으로 간주
	 * 
	 * 2. 여러 줄 주석(/*~*): 작성할 내용이 여러 줄일때 사용
	 * 	  주석 사이의 모든 내용을 주석으로 간주
	 */

	/*
	 * 패키지(package)
	 * 
	 * 소스코드를 작성할 때, 클래스를 만들어서 작업하는데
	 * 모든 클래스들을 동일한 패키지에 생성하여 관리하면 복잡하기 때문에
	 * 클래스들을 용도에 맞게 구분해서 패키지에 보관하는 것을 권장
	 * 
	 * 하나의 패키지 안에 여러 개의 클래스들이 존재할 수 있음
	 * 단, 동일한 이름의 클래스는 존재할 수 없음
	 * 
	 * 권장사항
	 * 
	 * 패키지는 적어도 세 단계 이상으로 만들어주는 것을 권장
	 * ex) com.kh.first
	 * 
	 * com.<회사이름>.<프로젝트/팀/카테고리/도메인 등>
	 */

public class HelloWorld { // 클래스명은 HelloWorld {	} = Scope / Block
	// Scope(Block) {	} 는 복합문을 구성하는 요소 종송된 문장이 여러줄일때 사용
	
	// main method: 프로그램의 시작점(Entry Point), 프로그램 당 1개는 있어야함
	public static void main(String[] args) { //() 있으면 메소드
		// Method: 하나의 기능 단위
		// 하나의 클래스 안에 여러 개의 메소드가 존재할 수 있음
		// 메소드 안의 구문을 수행하고 싶다면 반드시 *호출해야 한다
		
		System.out.print("Hello World"); // 출력을 할 때 사용
		// 논리적인 한 문장이 끝날 때 반드시 ; 을 붙임
			
	}
	
	public static void printMyName() { // 메소드 선언
		// 안녕하세요. 제 이름은 ~입니다. 반갑습니다.
		System.out.print("안녕하세요. 제 이름은 심영도입니다. 반갑습니다~");
		
	} // 메소드 영역 끝
	
}
